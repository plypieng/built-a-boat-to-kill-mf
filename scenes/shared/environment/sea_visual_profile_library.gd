static func get_profile(id: String) -> Dictionary:
	var profile := PROFILE_DEFAULTS.duplicate(true)
	var overrides: Dictionary = PROFILE_OVERRIDES.get(id, PROFILE_OVERRIDES.get(RunWorldGenerator.BIOME_OPEN_OCEAN, {}))
	for key_variant in overrides.keys():
		var key := str(key_variant)
		profile[key] = overrides[key_variant]
	return profile

static func blend_profiles(a: Dictionary, b: Dictionary, weight: float) -> Dictionary:
	var t := clampf(weight, 0.0, 1.0)
	var blended := a.duplicate(true)
	for key_variant in b.keys():
		var key := str(key_variant)
		var left: Variant = a.get(key)
		var right: Variant = b.get(key)
		if left == null:
			blended[key] = right
			continue
		match typeof(left):
			TYPE_FLOAT:
				blended[key] = lerpf(float(left), float(right), t)
			TYPE_INT:
				blended[key] = int(round(lerpf(float(left), float(right), t)))
			TYPE_COLOR:
				blended[key] = (left as Color).lerp(right as Color, t)
			TYPE_VECTOR2:
				blended[key] = (left as Vector2).lerp(right as Vector2, t)
			TYPE_VECTOR3:
				blended[key] = (left as Vector3).lerp(right as Vector3, t)
			_:
				blended[key] = right if t >= 0.5 else left
	return blended
